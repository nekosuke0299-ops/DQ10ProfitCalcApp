@page
@model ProfitCalcApp.Pages.ProfitModel
@{
    ViewData["Title"] = "DQ10 職人用計算Webニャン";
}
<!-- ↑上をいじればタイトルが変わる↑ -->

<h2>@ViewData["Title"]</h2>

<form method="post" style="max-width: 440px; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; margin-bottom: 8px;">
        <label style="width: 90px; text-align: right; margin-right: 10px;">タイトル</label>
        <input asp-for="Title"
               style="flex: 1; padding: 4px 8px; border-radius: 5px; border: 1px solid #ccc; font-size: 0.95rem; height: 28px;" />
    </div>

    <div style="display: flex; align-items: center; margin-bottom: 8px;">
        <label style="width: 90px; text-align: right; margin-right: 10px;">原価</label>
        <input asp-for="Cost"
               style="flex: 1; padding: 4px 8px; border-radius: 5px; border: 1px solid #ccc; font-size: 0.95rem; height: 28px;" />
    </div>

    <div style="display: flex; align-items: center; margin-bottom: 8px;">
        <label style="width: 90px; text-align: right; margin-right: 10px;">販売価格</label>
        <input asp-for="Price"
               style="flex: 1; padding: 4px 8px; border-radius: 5px; border: 1px solid #ccc; font-size: 0.95rem; height: 28px;" />
    </div>

    <div style="display: flex; align-items: center; margin-bottom: 8px;">
        <label style="width: 90px; text-align: right; margin-right: 10px;">数量</label>
        <input asp-for="Quantity"
               style="flex: 1; padding: 4px 8px; border-radius: 5px; border: 1px solid #ccc; font-size: 0.95rem; height: 28px;" />
    </div>

    <div style="display: flex; align-items: flex-start; margin-bottom: 8px;">
        <label style="width: 90px; text-align: right; margin-right: 10px; padding-top: 5px;">メモ</label>
        <textarea asp-for="Note" rows="2"
                  style="flex: 1; padding: 5px 8px; border-radius: 5px; border: 1px solid #ccc; font-size: 0.95rem; resize: vertical; min-height: 50px;"></textarea>
    </div>

    <div style="display: flex; align-items: center; margin-bottom: 10px;">
        <label style="width: 90px; text-align: right; margin-right: 10px;">画像</label>
        <select asp-for="SelectedImage" class="form-control"
                style="flex: 1; padding: 4px 8px; border: 1px solid #ccc; border-radius: 5px; font-size: 0.95rem; height: 30px;">
            <option value="">画像を選択してください</option>
            <option value="アクエリアスガード.png">アクエリアスガード</option>
            <option value="shield.png">て</option>
            <option value="potion.png">てす</option>
            <option value="coin.png">テスト</option>
        </select>
    </div>

    <div style="text-align: right;">
        <button type="submit" class="btn btn-primary"
                style="padding: 5px 16px; font-size: 0.95rem; border-radius: 5px;">
            保存
        </button>
    </div>
</form>




@if (Model.ResultMessage != null)
{
    <div style="margin-top:10px; color:green; font-weight:bold;">
        @Model.ResultMessage
    </div>
}

<hr />

<!-- 🔍 検索フォーム -->
<form method="get" style="margin-bottom: 16px; display: flex; align-items: center; gap: 10px;">
    <input type="text" name="SearchTitle" value="@Model.SearchTitle" placeholder="タイトルで検索"
            style="padding:6px; width:200px; border:1px solid #ccc; border-radius:6px;" />

    @{
        // 選択可能な画像リスト
        var images = new Dictionary<string, string>
        {
            { "アクエリアスガード.png", "アクエリアスガード" },
            { "shield.png", "盾" },
            { "potion.png", "ポーション" },
            { "coin.png", "コイン" }
            //{ "newimage.png", "選択バーに表示される名前" },新しく追加するときはこの形式で書く

        };
    }

    <select name="SearchImage" style="padding:6px; border:1px solid #ccc; border-radius:6px;">
        <option value="">画像を選択</option>
        @foreach (var img in images)
        {
            <option value="@img.Key" selected="@(Model.SearchImage == img.Key ? "selected" : null)">
                @img.Value
            </option>
        }
    </select>

    <button type="submit" class="btn btn-secondary">検索</button>
    <a href="/Profit" class="btn btn-light" style="border:1px solid #ccc;">リセット</a>
</form>

<h3>履歴</h3>

@foreach (var record in Model.History)
{
    <div style="
    border: 3px solid white;
    border-radius: 12px;
    padding: 10px 14px;
    margin-bottom: 12px;
    background-color: rgba(92, 92, 92, 0.25);
    font-family: 'Fredoka', 'Rounded Mplus 1c', 'Arial Rounded MT Bold', sans-serif;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
    color: white;
">
    <!-- ✅ タイトル＋画像 -->
    <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
        @if (!string.IsNullOrEmpty(record.ImagePath))
        {
            <img src="@record.ImagePath" alt="画像"
                style="width:55px; height:55px; object-fit:cover; border-radius:8px; border:2px solid #fff;" />
        }
        <div style="
            font-size:1.3em;
            font-weight:900;
            color:#fff;
            letter-spacing:0.5px;
            text-shadow:
                -1px -1px 0 #000,
                1px -1px 0 #000,
                -1px  1px 0 #000,
                1px  1px 0 #000;
        ">
            @record.Title
        </div>
    </div>

    <div style="
        font-size:1em;
        font-weight:700;
        opacity:0.9;
        margin-bottom:4px;
        letter-spacing:0.3px;
        text-shadow:
            -1px -1px 0 #000,
            1px -1px 0 #000,
            -1px  1px 0 #000,
            1px  1px 0 #000;
    ">
        @record.CreatedAt.ToString("yyyy/MM/dd HH:mm")
    </div>

    <div style="
        margin-bottom:4px;
        font-size:1em;
        font-weight:600;
        line-height:1.4em;
        text-shadow:
            -1px -1px 0 #000,
            1px -1px 0 #000,
            -1px  1px 0 #000,
            1px  1px 0 #000;
    ">
        <strong>メモ :</strong> @record.Note
    </div>

    <div style="
        margin-bottom:4px;
        font-size:1.3em;
        font-weight:600;
        line-height:1.4em;
        text-shadow:
            -1px -1px 0 #000,
            1px -1px 0 #000,
            -1px  1px 0 #000,
            1px  1px 0 #000;
    ">
        原価 : <strong>@((int)record.Cost)</strong> ／ 
        価格 : <strong>@((int)record.Price)</strong> ／ 
        数量 : <strong>@record.Quantity</strong>
    </div>

    <div style="
        color:#00ff66;
        font-weight:900;
        font-size:1.5em;
        text-shadow:
            -1px -1px 0 #000,
            1px -1px 0 #000,
            -1px  1px 0 #000,
            1px  1px 0 #000;
    ">
        利益 : @((int)record.Profit) G<!-- 円からGへ変更した -->
    </div>
</div>


}


