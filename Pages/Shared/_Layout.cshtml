<!DOCTYPE html>
<html lang="en">
<head>

<!-- ↓フォント部分 -->
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&family=Rounded+Mplus+1c:wght@400;700&display=swap" rel="stylesheet">
<!-- ↑まるっこい履歴の部分のフォント -->

<link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700&display=swap" rel="stylesheet">
<!-- ↑どこでつかったか覚えてねえ多分テスト用のフォント -->

<style>
    body {
        font-family: 'M PLUS Rounded 1c', sans-serif;
        background-color: #f5f5f5;
    }
</style>
<!-- ↑フォント部分 -->

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] DQ10 職人用計算Webニャン</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProfitCalcApp.styles.css" asp-append-version="true" />

    <!-- ↓ドラクエ風のフォント -->
<link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700&display=swap" rel="stylesheet">


<style>
    body {
        font-family: 'M PLUS Rounded 1c', 'メイリオ', sans-serif;
        background: linear-gradient(to bottom right, #dbe9ff, #f0f7ff);
        color: #222;
        margin: 0;
        padding: 0;
    }

    header, footer {
        background: #003366;
        color: #fff;
        text-shadow: 2px 2px 0 #000;
        padding: 10px 20px;
        font-weight: bold;
        border-bottom: 3px solid #88ccff;
    }

    main {
        padding: 20px;
    }

    h2, h3 {
        color: #003366;
        text-shadow: 1px 1px 0 #fff;
        font-weight: 700;
    }

    .btn {
        border-radius: 6px;
        font-family: inherit;
        transition: all 0.15s ease;
    }

    .btn-primary {
        background-color: #1a4fc3;
        border: 1px solid #113a8a;
        color: white;
    }

    .btn-primary:hover {
        background-color: #2d6bff;
    }

    .btn-secondary {
        background-color: #ffcc00;
        border: 1px solid #cc9900;
        color: #000;
    }

    .btn-secondary:hover {
        background-color: #ffdd33;
    }

    /* 🎲 ドラクエ風のウィンドウ */
    .dq-window {
        background-color: #e7f1ff;
        border: 2px solid #003366;
        border-radius: 10px;
        box-shadow: 4px 4px 0 #003366;
        padding: 10px 16px;
    }
</style>


</head>
<body><!-- 画面上部のバーの中身 -->
<header style="background-color:#1c1c1c; padding:10px 0; text-align:center; box-shadow:0 2px 6px rgba(0,0,0,0.6);">
    <h1 style="
        font-family:'Fredoka','Rounded Mplus 1c','Arial Rounded MT Bold',sans-serif;
        color:#fff;
        text-shadow:
            -2px -2px 0 #000,
            2px -2px 0 #000,
            -2px  2px 0 #000,
            2px  2px 0 #000;
        font-size:1.6em;
        letter-spacing:1px;
        margin:0;
    ">
        ⚒️ DQ10 職人用計算ツール ⚒️
    </h1>
    <div style="margin-top:4px;">
        <span style="color:#ccc; font-size:0.9em;">製作者：</span>
        <a href="https://twitter.com/peco_princess31" target="_blank" style="
            color:#1DA1F2;
            font-weight:bold;
            text-decoration:none;
            text-shadow:
                -1px -1px 0 #000,
                1px -1px 0 #000,
                -1px  1px 0 #000,
                1px  1px 0 #000;
        ">
            @@peco_princess31
        </a>
    </div>
</header>


    <div class="container">
        <main role="main" class="pb-3">
            <div class="dq-window">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ProfitCalcApp - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>